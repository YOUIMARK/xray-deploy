{
    "listen": "127.0.0.1",
    "port": {{PORT}},
    "protocol": "tunnel",
    "tag": "{{TAG}}",
    "settings": {
        "allowedNetwork": "tcp",
        "rewriteAddress": "{{TARGET}}",
        "rewritePort": 443
    },
    "sniffing": {
        "enabled": true,
        "destOverride": ["tls"],
        "routeOnly": true
    }
}
